rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper primitives
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validator: Player
    function isValidPlayer(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt'])
        && data.keys().size() == 3
        && data.id is int
        && data.name is string
        && data.name.size() <= 64
        && data.name.size() > 0
        && data.createdAt is string;
    }

    // Entity validator: Season
    function isValidSeason(data) {
      return data.keys().hasAll([
        'id', 'name', 'startedAt', 'endedAt',
        'xpPerDefeatedOpponent', 'xpBonusSimple', 'xpBonusDouble', 'xpBonusTriple',
        'xpVampireMultiplier', 'xpSurvivorBase', 'xpBonusPoulidor', 'xpBonusJackpot',
        'xpBonusEgalite', 'xpBonusTueurDeGeants', 'xpBonusPhenix', 'xpBonusSerialWinner',
        'xpBonusBenjamin', 'xpBonusLottery', 'bonusVainqueurParRang'
      ])
      && data.id is int
      && data.name is string
      && data.name.size() <= 100
      && data.startedAt is string
      && (data.endedAt == null || data.endedAt is string)
      && data.xpPerDefeatedOpponent is int
      && data.xpBonusSimple is int
      && data.xpBonusDouble is int
      && data.xpBonusTriple is int
      && (data.xpVampireMultiplier is float || data.xpVampireMultiplier is int)
      && data.xpSurvivorBase is int
      && data.xpBonusPoulidor is int
      && data.xpBonusJackpot is int
      && data.xpBonusEgalite is int
      && data.xpBonusTueurDeGeants is int
      && data.xpBonusPhenix is int
      && data.xpBonusSerialWinner is int
      && data.xpBonusBenjamin is int
      && data.xpBonusLottery is int
      && data.bonusVainqueurParRang is bool;
    }

    // Entity validator: Match
    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'seasonId', 'playedAt', 'participants'])
        && (data.keys().size() == 4 || (data.keys().size() == 5 && data.keys().contains('excluded')))
        && data.id is int
        && data.seasonId is int
        && data.playedAt is string
        && data.participants is list
        && data.participants.size() <= 20
        && (data.participants.size() == 0 || data.participants[0] is map)
        && (!data.keys().contains('excluded') || data.excluded is bool);
    }

    // Entity validator: Guild
    function isValidGuild(data) {
      return data.keys().hasAll(['id', 'name', 'badgeIcon', 'badgeColor', 'createdAt', 'memberIds'])
        && data.id is int
        && data.name is string
        && data.name.size() <= 100
        && data.badgeIcon is string
        && data.badgeColor is string
        && data.createdAt is string
        && data.memberIds is list
        && data.memberIds.size() <= 100
        && (data.memberIds.size() == 0 || data.memberIds[0] is int)
        && (!data.keys().contains('password') || data.password == null || data.password is string)
        && (!data.keys().contains('creatorId') || data.creatorId == null || data.creatorId is int);
    }

    // Entity validator: AdminSettings
    function isValidAdminSettings(data) {
      return data.keys().hasAll(['adminPassword'])
        && data.keys().size() == 1
        && data.adminPassword is string
        && data.adminPassword.size() <= 100;
    }

    // Entity validator: MatchLog
    function isValidMatchLog(data) {
      return data.keys().hasAll(['id', 'matchId', 'action', 'timestamp', 'details'])
        && data.id is string
        && data.matchId is int
        && data.action is string
        && data.timestamp is string
        && data.details is string
        && (!data.keys().contains('author') || data.author is string);
    }

    // --- Matches / Allow rules for collections ---

    match /players/{playerId} {
      allow read: if true;
      allow create, update: if isValidId(playerId) && isValidPlayer(incoming());
      allow delete: if isValidId(playerId);
    }

    match /seasons/{seasonId} {
      allow read: if true;
      allow create, update: if isValidId(seasonId) && isValidSeason(incoming());
      allow delete: if isValidId(seasonId);
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isValidId(matchId) && isValidMatch(incoming());
      allow delete: if isValidId(matchId);
    }

    match /guilds/{guildId} {
      allow read: if true;
      allow create, update: if isValidId(guildId) && isValidGuild(incoming());
      allow delete: if isValidId(guildId);
    }

    match /adminSettings/{settingsId} {
      allow read: if true;
      allow create, update: if isValidId(settingsId) && isValidAdminSettings(incoming());
      allow delete: if isValidId(settingsId);
    }

    match /matchLogs/{logId} {
      allow read: if true;
      allow create, update: if isValidId(logId) && isValidMatchLog(incoming());
      allow delete: if isValidId(logId);
    }
  }
}
