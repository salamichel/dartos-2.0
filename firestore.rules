rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper primitives
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validator: Player
    function isValidPlayer(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt']);
    }

    // Entity validator: Season
    function isValidSeason(data) {
      return data.keys().hasAll([
        'id', 'name', 'startedAt', 'endedAt',
        'xpPerDefeatedOpponent', 'xpBonusSimple', 'xpBonusDouble', 'xpBonusTriple',
        'xpVampireMultiplier', 'xpSurvivorBase', 'xpBonusPoulidor', 'xpBonusJackpot',
        'xpBonusEgalite', 'xpBonusTueurDeGeants', 'xpBonusPhenix', 'xpBonusSerialWinner',
        'xpBonusBenjamin', 'xpBonusLottery', 'bonusVainqueurParRang'
      ]);
    }

    // Entity validator: Match
    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'seasonId', 'playedAt', 'participants']);
    }

    // Entity validator: Guild
    function isValidGuild(data) {
      return data.keys().hasAll(['id', 'name', 'badgeIcon', 'badgeColor', 'createdAt', 'memberIds']);
    }

    // Entity validator: AdminSettings
    function isValidAdminSettings(data) {
      return data.keys().hasAll(['adminPassword']);
    }

    // Entity validator: MatchLog
    function isValidMatchLog(data) {
      return data.keys().hasAll(['id', 'matchId', 'action', 'timestamp', 'details']);
    }

    // --- Matches / Allow rules for collections ---

    match /players/{playerId} {
      allow read: if true;
      allow create, update: if isValidId(playerId) && isValidPlayer(incoming());
      allow delete: if isValidId(playerId);
    }

    match /seasons/{seasonId} {
      allow read: if true;
      allow create, update: if isValidId(seasonId) && isValidSeason(incoming());
      allow delete: if isValidId(seasonId);
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isValidId(matchId) && isValidMatch(incoming());
      allow delete: if isValidId(matchId);
    }

    match /guilds/{guildId} {
      allow read: if true;
      allow create, update: if isValidId(guildId) && isValidGuild(incoming());
      allow delete: if isValidId(guildId);
    }

    match /adminSettings/{settingsId} {
      allow read: if true;
      allow create, update: if isValidId(settingsId) && isValidAdminSettings(incoming());
      allow delete: if isValidId(settingsId);
    }

    match /matchLogs/{logId} {
      allow read: if true;
      allow create, update: if isValidId(logId) && isValidMatchLog(incoming());
      allow delete: if isValidId(logId);
    }
  }
}
